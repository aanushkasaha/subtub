# Copy this file to .env.development.local (or .env.production.local) and fill in real values.
# Note: this project loads env vars from .env.<NODE_ENV>.local, not a plain .env — see config/env.js

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database ---
# MongoDB connection string, e.g. from MongoDB Atlas
DB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/subtub

# --- Auth ---
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# --- Arcjet (rate limiting + bot detection) ---
# https://arcjet.com — free tier works fine for local dev
# Note: Arcjet middleware is skipped entirely when NODE_ENV=development,
# so this can be left blank locally, but env.js still requires the key to be set.
ARCJET_KEY=ajkey_xxx

# --- Upstash QStash (durable reminder workflow) ---
# https://upstash.com — free tier works fine for local dev
QSTASH_TOKEN=
QSTASH_URL=https://qstash.upstash.io
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Public URL QStash should call back to trigger the reminder workflow.
# Locally this needs to be a tunnel (e.g. ngrok) since QStash can't reach localhost.
SERVER_URL=http://localhost:3000

# --- Email (Nodemailer via Gmail) ---
# Gmail App Password, not your regular account password:
# https://myaccount.google.com/apppasswords
# Sender address is currently hardcoded in config/nodemailer.js
EMAIL_PASSWORD=
